# Copy this file to .env and adjust values for your environment.

# Docker Compose / database credentials
POSTGRES_DB=checkers
POSTGRES_USER=checkers
POSTGRES_PASSWORD=checkers_password

# Backend database connection
DB_HOST=db
DB_PORT=5432
DB_NAME=checkers
DB_USER=checkers
DB_PASSWORD=checkers_password

# Backend server
PORT=3001
# Comma-separated origins are supported, including wildcard hosts like https://*.trycloudflare.com
CORS_ORIGIN=http://localhost:8036
JWT_SECRET=change-me-in-production-please

# Frontend (optional; defaults to /api in Docker)
VITE_API_URL=/api

# Demo accounts for testing multiplayer quickly
# These are documentation values only; create users in the app manually.
DEMO_USER_1_USERNAME=player_one
DEMO_USER_1_PASSWORD=PlayerOne123!
DEMO_USER_2_USERNAME=player_two
DEMO_USER_2_PASSWORD=PlayerTwo123!
