# Copy this file to .env and adjust values for your environment.

# Docker Compose / database credentials
POSTGRES_DB=checkers
POSTGRES_USER=checkers
POSTGRES_PASSWORD=checkers_password

# Backend database connection
DB_HOST=db
DB_PORT=5432
DB_NAME=checkers
DB_USER=checkers
DB_PASSWORD=checkers_password

# Backend server
PORT=3001
# Allowed browser origins for the backend.
# Keep http://localhost:8036 for local access, then add every public tunnel/domain that points to this app.
# Use a comma-separated list with no spaces.
# Example with a custom Cloudflare Tunnel domain:
# CORS_ORIGIN=http://localhost:8036,https://ck.akalanka.me
# Example with a Cloudflare Quick Tunnel wildcard:
# CORS_ORIGIN=http://localhost:8036,https://*.trycloudflare.com
# After changing this value, rebuild or restart the backend so the new origin list is loaded.
CORS_ORIGIN=http://localhost:8036
JWT_SECRET=change-me-in-production-please

# Frontend API URL used at build time
# Keep this as /api so frontend uses same-origin requests.
# Frontend container proxies /api and /socket.io to backend internally.
VITE_API_URL=/api

# Demo accounts for testing multiplayer quickly
# Backend auto-creates these users on startup when all fields are non-empty.
DEMO_USER_1_USERNAME=user1
DEMO_USER_1_FIRST_NAME=User
DEMO_USER_1_LAST_NAME=1
DEMO_USER_1_EMAIL=user1@example.com
DEMO_USER_1_BIRTHDAY=1990-01-01
DEMO_USER_1_COUNTRY=Sri Lanka
DEMO_USER_1_PASSWORD=12345678

DEMO_USER_2_USERNAME=user2
DEMO_USER_2_FIRST_NAME=User
DEMO_USER_2_LAST_NAME=2
DEMO_USER_2_EMAIL=user2@example.com
DEMO_USER_2_BIRTHDAY=1990-01-01
DEMO_USER_2_COUNTRY=Sri Lanka
DEMO_USER_2_PASSWORD=12345678
