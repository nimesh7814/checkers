# Copy this file to .env and fill in production values before deploying.

# PostgreSQL (used by backend service)
DB_HOST=db
DB_PORT=5432
DB_NAME=checkers
DB_USER=checkers
DB_PASSWORD=checkers_password

# A long, random secret for signing JWTs – change this!
JWT_SECRET=change-me-in-production-please

# Backend server port
PORT=3001

# Comma-separated list of allowed CORS origins
CORS_ORIGIN=http://localhost
